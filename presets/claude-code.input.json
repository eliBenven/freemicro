{
  "$schema": "https://raw.githubusercontent.com/eliBenven/freemicro/main/presets/schema.json",
  "name": "Claude Code — Terminal",
  "description": "Recommended Work Louder Input layout for driving Claude Code from the terminal. Import into Work Louder Input; a VIA equivalent lives in claude-code.keyboard.json.",
  "agent": "claude-code",
  "target": "terminal",
  "version": "0.1.0",
  "layers": [
    {
      "name": "home",
      "color": [0, 122, 255],
      "dial": {
        "cw": "history-next",
        "ccw": "history-prev",
        "press": "Shift+Tab",
        "comment": "Rotate through prompt history; press to cycle permission modes."
      },
      "joystick": {
        "up": "Esc",
        "down": "EscEsc",
        "left": "@",
        "right": "!",
        "comment": "Interrupt (Esc), clear line (EscEsc), file-mention (@), bash-mode (!)."
      },
      "keys": [
        { "id": 1, "label": "claude", "send": "claude\n", "comment": "Launch/attach Claude Code." },
        { "id": 2, "label": "resume", "send": "/resume\n" },
        { "id": 3, "label": "clear", "send": "/clear\n" },
        { "id": 4, "label": "compact", "send": "/compact\n" },
        { "id": 5, "label": "model", "send": "/model\n" },
        { "id": 6, "label": "review", "send": "/review\n" },
        { "id": 7, "label": "reverse-search", "send": "Ctrl+R" },
        { "id": 8, "label": "accept", "send": "\n", "comment": "Accept / submit." },
        { "id": 9, "label": "cancel", "send": "Esc" },
        { "id": 10, "label": "memory", "send": "#", "comment": "Add a memory (#)." },
        { "id": 11, "label": "ptt", "send": "os-dictation", "comment": "Push-to-talk -> OS dictation toggle." }
      ]
    }
  ],
  "workflows": {
    "ship-it": ["/review\n", "accept", "!git commit -am 'wip'\n"],
    "fresh-context": ["/compact\n", "/clear\n"]
  }
}
